{
  "name": "nuxt-skills",
  "type": "module",
  "version": "0.0.0",
  "author": "Estéban Soubiran <esteban@soubiran.dev>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/Barbapapazes",
  "homepage": "https://github.com/Barbapapazes/unplugin-skills/tree/main/packages/nuxt-skills#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Barbapapazes/unplugin-skills/tree/main/packages/nuxt-skills"
  },
  "bugs": "https://github.com/Barbapapazes/unplugin-skills/issues",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "npm run build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8",
    "unplugin-skills": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^24.13.2",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
